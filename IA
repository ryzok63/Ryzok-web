  <script>
    document.addEventListener("DOMContentLoaded", () => {

      const input = document.getElementById("ia-search");

      const cities = [...document.querySelectorAll(".ia-city")];
      const container = cities[0].parentElement;

      function normalize(text) {
        return (text || "")
          .toLocaleLowerCase("tr-TR")
          .replaceAll("ı", "i")
          .replaceAll("ğ", "g")
          .replaceAll("ü", "u")
          .replaceAll("ş", "s")
          .replaceAll("ö", "o")
          .replaceAll("ç", "c")
          .trim();
      }

      const index = cities.map(city => ({
        element: city,
        city: normalize(city.dataset.city),
        districts: [...city.querySelectorAll(".ia-district")].map(d => ({
          element: d,
          name: normalize(d.dataset.ilce)
        }))
      }));

      input.addEventListener("input", () => {

        const q = normalize(input.value);


        document.querySelectorAll(".ia-district").forEach(d => {
          d.style.background = "";
          d.style.color = "";
        });

        if (q === "") {

          cities.forEach(c => {
            c.style.display = "";
            const br = c.nextElementSibling;
            if (br && br.tagName === "BR") {
              br.style.display = "";
            }
          });

          return;
        }

        let firstMatch = null;

        index.forEach(c => {

          let found = c.city.includes(q);

          c.districts.forEach(d => {

            if (d.name.includes(q)) {

              found = true;

              d.style = d.style;
              d.element.style.background = "#ffe36d";
              d.element.style.color = "#000";

              if (!firstMatch) {
                firstMatch = {
                  city: c.element,
                  district: d.element
                };
              }
            }

          });

          c.element.style.display = found ? "" : "none";

          // Şehrin arkasındaki <br>'yi de gizle/göster
          const br = c.element.nextElementSibling;
          if (br && br.tagName === "BR") {
            br.style.display = found ? "" : "none";
          }

        });

        if (firstMatch) {

          container.prepend(firstMatch.city);

          firstMatch.district.scrollIntoView({
            behavior: "smooth",
            block: "center"
          });

        }

      });

    });





    // Kopyalama fonksiyonu
    function fnc_kopyala_q7(element) {
      const satir = element.parentElement;
      const satirMetni = satir.innerText.trim();

      navigator.clipboard.writeText(satirMetni).then(() => {
        satir.classList.add('komple-yesil-zort');
        setTimeout(() => {
          satir.classList.remove('komple-yesil-zort');
        }, 400);
      }).catch(err => console.error("Hata:", err));
    }


  </script>


