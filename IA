        { konu: "GÖZETİM NEDİR? SINAVLARINA GİRMİŞ OLDUĞUM KURULUŞ BENDEN ÇEŞİTLİ BELGELER İSTİYOR, BU BELGELERİ VERMEK ZORUNDA MIYIM?", metin: `GÖZETİM, MYK BELGESİ SAHİBİNİN GEÇERLİLİK SÜRESİ İÇERİSİNDE İLGİLİ MESLEKİ YETERLİLİĞİ SÜRDÜRDÜĞÜNÜN İZLENMESİDİR. YETKİLENDİRİLMİŞ BELGELENDİRME KURULUŞLARI AKTİF OLARAK ÇALIŞTIĞINIZI GÖSTERİR KANITLARI TALEP EDER, VERİLMEZSE BELGE ASKIYA ALINABİLİR VEYA İPTAL EDİLEBİLİR.` },
        { konu: "SINAV SONUCUNDA 90 PUAN ALDIĞIM AMA BAŞARISIZ OLDUĞUM YAZIYOR, BU NASIL MÜMKÜN OLUYOR?", metin: `ULUSAL YETERLİLİKLERİN BÜYÜK BİR ÇOĞUNLUĞUNDA KRİTİK ADIMLAR YER ALMAKTADIR. KRİTİK ADIM, SINAVIN BAŞARIYLA TAMAMLANMASI İÇİN ADAYIN MUTLAKA EKSİKSİZ YERİNE GETİRMESİ GEREKEN İŞLEMLERİ İFADE EDER, BU ADIMLARDAN BAŞARISIZ OLANLAR SINAVDAN KALIRLAR.` },
        { konu: "SINAV SONUÇLARIMI VE BELGE HAK EDİP ETMEDİĞİMİ NEREDEN ÖĞRENEBİLİRİM ?", metin: `MYK WEB PORTALINDAKİ “SORGULAMA” BAŞLIĞI ALTINDAKİ ADAY SORGULAMA BÖLÜMÜNDEN VEYA E-DEVLET KAPISI ÜZERİNDEN SINAV SONUÇLARINIZI GÖREBİLİRSİNİZ. BELGE TALEBİ İLETİLDİKTEN SONRA EN GEÇ 5 İŞ GÜNÜ İÇERİSİNDE BELGE VE KİMLİK KARTLARI HAZIRLANIR.` }
