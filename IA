    function turkceKucukHarf(str) {
      return str.replace(/İ/g, "i").replace(/I/g, "ı").replace(/Ş/g, "ş").replace(/Ç/g, "ç").replace(/Ğ/g, "ğ").replace(/Ü/g, "ü").replace(/Ö/g, "ö").toLowerCase();
    }

    function copyToClipboard(text, targetBox, targetBadge) {
      if (!text || text === "-" || text.trim() === "") return;
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text).then(() => {
          showCopiedState(targetBox, targetBadge);
        }).catch(() => {
          fallbackCopy(text, targetBox, targetBadge);
        });
      } else {
        fallbackCopy(text, targetBox, targetBadge);
      }
    }

    function fallbackCopy(text, targetBox, targetBadge) {
      const textArea = document.createElement("textarea");
      textArea.value = text;
      textArea.style.position = "fixed";
      textArea.style.opacity = "0";
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      try {
        document.execCommand('copy');
        showCopiedState(targetBox, targetBadge);
      } catch (err) {
        console.error('Kopyalama başarısız oldu: ', err);
      }
      document.body.removeChild(textArea);
    }

    function showCopiedState(box, badge) {
      box.classList.add('copied-success');
      badge.textContent = "Kopyalandı!";
      badge.style.backgroundColor = "#4caf50";
      badge.style.color = "#ffffff";
      setTimeout(() => {
        box.classList.remove('copied-success');
        badge.textContent = "Tıkla Kopyala";
        badge.style.backgroundColor = "#e3dabc";
        badge.style.color = "#5d4a38";
      }, 1500);
    }

