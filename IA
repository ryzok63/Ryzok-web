  <script>

    // Kopyalama fonksiyonu
    function sacma_kopya_fnc(element) {
      const satir = element.parentElement;
      const satirMetni = satir.innerText.trim();

      navigator.clipboard.writeText(satirMetni).then(() => {
        satir.classList.add('satir-kopya-yeesil');
        setTimeout(() => {
          satir.classList.remove('satir-kopya-yeesil');
        }, 400);
      }).catch(err => console.error("Hata:", err));
    }

    // Canlı Arama filtreleme fonksiyonu (Düzeltilmiş)
    function sacma_ara_fnc() {
      const input = document.getElementById('id-sacma-input-ara');
      // Türkçe karakter uyumu için toLocaleUpperCase('tr-TR')
      const filter = input.value.toLocaleUpperCase('tr-TR');
      const rows = document.querySelectorAll('#id-sacma-panel-wrapper tbody tr');

      rows.forEach(row => {
        let match = false;
        const cells = row.getElementsByTagName('td');

        for (let i = 0; i < cells.length; i++) {
          // Hücre içindeki metni de Türkçe kurallara göre çeviriyoruz
          if (cells[i].innerText.toLocaleUpperCase('tr-TR').indexOf(filter) > -1) {
            match = true;
            break;
          }
        }

        row.style.display = match ? "" : "none";
      });
    }
  </script>










