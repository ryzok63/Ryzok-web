  <script>


    // Senin mevcut Filtreleme ve Tab Kodların
    let currentProvince = 'Tümü';
    const searchInput = document.getElementById('searchInput');
    const tableRows = document.querySelectorAll('#sgkTable tbody tr');
    const noResults = document.getElementById('noResults');

    searchInput.addEventListener('input', filterData);

    function filterProvince(province, element) {
      document.querySelectorAll('.tab-btn44').forEach(btn => btn.classList.remove('active'));
      element.classList.add('active');
      currentProvince = province;
      filterData();
    }

    function filterData() {
      // Türkçe karakter duyarlılığı için toLocaleLowerCase('tr-TR') kullanıldı
      const searchTerm = searchInput.value.toLocaleLowerCase('tr-TR').trim();
      let visibleRowsCount = 0;

      tableRows.forEach(row => {
        const rowProvince = row.getAttribute('data-il');
        // Türkçe karakter uyumu için burası da güncellendi
        const textContent = row.textContent.toLocaleLowerCase('tr-TR');

        const matchesProvince = (currentProvince === 'Tümü' || rowProvince === currentProvince);
        const matchesSearch = textContent.includes(searchTerm);

        if (matchesProvince && matchesSearch) {
          row.style.display = '';
          visibleRowsCount++;
        } else {
          row.style.display = 'none';
        }
      });

      noResults.style.display = visibleRowsCount === 0 ? 'block' : 'none';
    }
  </script>







