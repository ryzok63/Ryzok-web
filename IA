    // =========================================================================
    // KLAVYE VE MOUSE'U BİRLEŞTİREN GÜNCEL FONKSİYON
    // =========================================================================

    function klavyeDestegiEkle(inputElement, dropdownElement) {
      // 1. Ok tuşları ve Enter ile seçim mantığı
      inputElement.addEventListener('keydown', function (e) {
        const items = dropdownElement.querySelectorAll('.custom-dropdown-item2');
        if (dropdownElement.style.display !== 'block' || items.length === 0) return;

        let activeIndex = Array.from(items).findIndex(item => item.classList.contains('active-item'));

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (activeIndex < items.length - 1) {
            if (activeIndex > -1) items[activeIndex].classList.remove('active-item');
            items[++activeIndex].classList.add('active-item');
            items[activeIndex].scrollIntoView({ block: 'nearest' });
          }
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (activeIndex > 0) {
            items[activeIndex].classList.remove('active-item');
            items[--activeIndex].classList.add('active-item');
            items[activeIndex].scrollIntoView({ block: 'nearest' });
          }
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (activeIndex > -1 && items[activeIndex]) {
            items[activeIndex].click();
          }
        }
      });

      // 2. MOUSE HAREKET ETTİKÇE KLAVYE SEÇİMİNİ GÜNCELLE
      dropdownElement.addEventListener('mouseover', function (e) {
        const target = e.target.closest('.custom-dropdown-item2');
        if (target) {
          // Önceki aktif sınıfı temizle
          const currentActive = dropdownElement.querySelector('.active-item');
          if (currentActive) currentActive.classList.remove('active-item');

          // Mouse'un geldiği öğeye active-item ekle
          target.classList.add('active-item');
        }
      });
    }

    // Tüm arama alanlarını bu yeni fonksiyona bağlıyoruz
    klavyeDestegiEkle(konuSearchInput, customDropdownList);
    klavyeDestegiEkle(guncelSearchInput, dropdownList3);
    klavyeDestegiEkle(searchInput2, dropdownList2);
  </script>

