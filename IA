  <script>

    // Canlı Arama / Filtreleme Fonksiyonu (Düzeltilmiş)
    function sgkTabloFiltrele() {
      const input = document.getElementById("sgkTabloAramaInput");
      // Türkçe karakter duyarlılığı için tr-TR formatı
      const filter = input.value.toLocaleUpperCase('tr-TR');
      const table = document.getElementById("sgkAnaTablo");
      const tr = table.getElementsByTagName("tr");

      for (let i = 1; i < tr.length; i++) {
        let tdKod = tr[i].getElementsByTagName("td")[0];
        let tdNeden = tr[i].getElementsByTagName("td")[1];
        if (tdKod || tdNeden) {
          let txtKod = tdKod.textContent || tdKod.innerText;
          let txtNeden = tdNeden.textContent || tdNeden.innerText;
          // Hem metinleri hem de aranan kelimeyi Türkçe kuralıyla büyük harfe çeviriyoruz
          if (txtKod.toLocaleUpperCase('tr-TR').indexOf(filter) > -1 || txtNeden.toLocaleUpperCase('tr-TR').indexOf(filter) > -1) {
            tr[i].style.display = "";
          } else {
            tr[i].style.display = "none";
          }
        }
      }
    }

    // Satıra Tıklayınca Yeşil Yapma ve Kopyalama Fonksiyonu
    function sgkSatirKopyalaDirekt(trSatir) {
      const tumSatirlar = document.getElementById("sgkAnaTablo").getElementsByTagName("tbody")[0].getElementsByTagName("tr");

      // Önceki seçilen satırların inline stillerini sıfırla
      for (let i = 0; i < tumSatirlar.length; i++) {
        tumSatirlar[i].style.backgroundColor = "";
        tumSatirlar[i].getElementsByTagName("td")[0].style.backgroundColor = "";
      }

      // Tıklanan güncel satırı ve içindeki KOD alanını ANINDA yeşil yap
      trSatir.style.backgroundColor = "#c2f0c2";
      trSatir.getElementsByTagName("td")[0].style.backgroundColor = "#c2f0c2";

      // Verileri Topla
      const cells = trSatir.getElementsByTagName("td");
      const kod = cells[0].innerText;
      const neden = cells[1].innerText;
      const iskur = cells[2].innerText;
      const issizlik = cells[3].innerText;
      const kidem = cells[4].innerText;
      const ihbar = cells[5].innerText;

      const metin = `SGK Kod: ${kod}\nNeden: ${neden}\nİŞKUR Karşılığı: ${iskur}\nİşsizlik Ödeneği: ${issizlik}\nKıdem: ${kidem}\nİhbar: ${ihbar}`;

      // Hafızaya Kopyala
      navigator.clipboard.writeText(metin).catch(err => {
        alert("Kopyalama başarısız oldu.");
      });
    }
  </script>











