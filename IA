    function evaluateYasStatus(yasStr, dogumDate) {
      if (!yasStr || yasStr === "-" || !dogumDate) return yasStr;

      if (yasStr.includes("YOK") || yasStr.includes("Aranmaz")) {
        return `${yasStr} <div class="status-badge status-success"> ŞARTI SAĞLADINIZ</div>`;
      }

      let match = yasStr.match(/(\d{2})/);
      if (!match) return yasStr;

      let targetAge = parseInt(match[1], 10);

      let hedefDate = new Date(dogumDate);
      hedefDate.setFullYear(hedefDate.getFullYear() + targetAge);
      let today = new Date();

      let g = ('0' + hedefDate.getDate()).slice(-2);
      let m = ('0' + (hedefDate.getMonth() + 1)).slice(-2);
      let y = hedefDate.getFullYear();
      let formattedDate = `${g}.${m}.${y}`;

      if (today >= hedefDate) {
        return `${yasStr} <div class="status-badge status-success"> ŞARTI SAĞLADINIZ</div>`;
      } else {
        return `${yasStr} <div class="status-badge status-fail"> ŞARTI SAĞLAMADINIZ<span class="status-subtext">Yaşın Dolacağı Tarih: <b>${formattedDate}</b></span></div>`;
      }
    }

    function evaluateSureStatus(sureStr, baslangicDate) {
      if (!sureStr || sureStr.includes("Yok") || sureStr === "-") return sureStr;

      let years = 0, months = 0;
      let yearMatch = sureStr.match(/(\d+)\s*Yıl/i);
      if (yearMatch) years = parseInt(yearMatch[1], 10);

      let monthMatch = sureStr.match(/(\d+)\s*Ay/i);
      if (monthMatch) months = parseInt(monthMatch[1], 10);

      if (years === 0 && months === 0) return sureStr;

      let hedefDate = new Date(baslangicDate);
      hedefDate.setFullYear(hedefDate.getFullYear() + years);
      hedefDate.setMonth(hedefDate.getMonth() + months);
      let today = new Date();

      let g = ('0' + hedefDate.getDate()).slice(-2);
      let m = ('0' + (hedefDate.getMonth() + 1)).slice(-2);
      let y = hedefDate.getFullYear();
      let formattedDate = `${g}.${m}.${y}`;

      if (today >= hedefDate) {
        return `${sureStr} <div class="status-badge status-success"> ŞARTI SAĞLADINIZ</div>`;
      } else {
        return `${sureStr} <div class="status-badge status-fail">ŞARTI SAĞLAMADINIZ<span class="status-subtext">Dolacağı Tarih: <b>${formattedDate}</b></span></div>`;
      }
    }

    function evaluatePrimStatus(primStr, toplamPrim) {
      if (!primStr || primStr === "-") return primStr;

      let targetMatch = primStr.match(/(\d{4,5})/);
      if (!targetMatch) return primStr;

      let target = parseInt(targetMatch[1], 10);
      let current = parseInt(toplamPrim, 10) || 0;

      if (current >= target) {
        return `${primStr} <div class="status-badge status-success"> ŞARTI SAĞLADINIZ</div>`;
      } else {
        let kalan = target - current;
        let months = Math.floor(kalan / 30);
        let days = kalan % 30;
        let d = new Date();
        d.setMonth(d.getMonth() + months);
        d.setDate(d.getDate() + days);

        let g = ('0' + d.getDate()).slice(-2);
        let m = ('0' + (d.getMonth() + 1)).slice(-2);
        let y = d.getFullYear();

        return `${primStr} <div class="status-badge status-fail">ŞARTI SAĞLAMADINIZ<span class="status-subtext">Eksik: <b>${kalan} Gün</b><br>Aralıksız Çalışılırsa: <b>${g}.${m}.${y}</b></span></div>`;
      }
    }

    function getKismiYas(kurum, cns, dgm, baslangic, trueBaslangic, toplamPrim) {
      let dateAge = new Date(dgm);
      dateAge.setFullYear(dateAge.getFullYear() + (cns === "Kadin" ? 50 : 55));

      if (kurum === "4A") {
        let date15 = new Date(trueBaslangic);
        date15.setFullYear(date15.getFullYear() + 15);

        let date3600 = new Date();
        if (toplamPrim < 3600) {
          date3600.setDate(date3600.getDate() + (3600 - toplamPrim));
        } else {
          date3600 = new Date(baslangic);
          date3600.setDate(date3600.getDate() + 3600);
          if (date3600 > new Date()) date3600 = new Date();
        }

        let dolmaTarihi = new Date(Math.max(date15.getTime(), date3600.getTime(), dateAge.getTime()));

        if (dolmaTarihi >= new Date('2014-05-24')) {
          return cns === "Erkek" ? "60 Yaş" : "58 Yaş";
        }

        if (cns === "Kadin") {
          if (dolmaTarihi <= new Date('2002-05-23')) return "50 Yaş";
          if (dolmaTarihi <= new Date('2005-05-23')) return "52 Yaş";
          if (dolmaTarihi <= new Date('2008-05-23')) return "54 Yaş";
          if (dolmaTarihi <= new Date('2011-05-23')) return "56 Yaş";
          return "58 Yaş";
        } else {
          if (dolmaTarihi <= new Date('2002-05-23')) return "55 Yaş";
          if (dolmaTarihi <= new Date('2005-05-23')) return "56 Yaş";
          if (dolmaTarihi <= new Date('2008-05-23')) return "57 Yaş";
          if (dolmaTarihi <= new Date('2011-05-23')) return "58 Yaş";
          if (dolmaTarihi <= new Date('2014-05-23')) return "59 Yaş";
          return "60 Yaş";
        }
      } else {
        let date5400 = new Date();
        if (toplamPrim < 5400) {
          date5400.setDate(date5400.getDate() + (5400 - toplamPrim));
        } else {
          date5400 = new Date(baslangic);
          date5400.setDate(date5400.getDate() + 5400);
          if (date5400 > new Date()) date5400 = new Date();
        }

        let dolmaTarihi = new Date(Math.max(date5400.getTime(), dateAge.getTime()));

        if (dolmaTarihi >= new Date('2008-10-01')) {
          return cns === "Erkek" ? "63 Yaş" : "61 Yaş";
        }

        if (cns === "Kadin") {
          if (dolmaTarihi <= new Date('2004-06-01')) return "50 Yaş";
          if (dolmaTarihi <= new Date('2006-06-01')) return "51 Yaş";
          if (dolmaTarihi <= new Date('2008-06-01')) return "52 Yaş";
          if (dolmaTarihi <= new Date('2010-06-01')) return "53 Yaş";
          if (dolmaTarihi <= new Date('2012-06-01')) return "54 Yaş";
          return "56 Yaş";
        } else {
          if (dolmaTarihi <= new Date('2004-06-01')) return "55 Yaş";
          if (dolmaTarihi <= new Date('2008-06-01')) return "56 Yaş";
          if (dolmaTarihi <= new Date('2010-06-01')) return "57 Yaş";
          if (dolmaTarihi <= new Date('2012-06-01')) return "58 Yaş";
          return "58 Yaş";
        }
      }
    }

    function getSonrasiYas(cns, d_effective, isKismi) {
      let base = cns === "Erkek" ? 60 : 58;
      if (isKismi) {
        base = cns === "Erkek" ? 63 : 61;
      }

      if (d_effective <= new Date('2035-12-31')) return base + " Yaş";
      else if (d_effective <= new Date('2037-12-31')) return Math.min(65, base + 1) + " Yaş";
      else if (d_effective <= new Date('2039-12-31')) return Math.min(65, base + 2) + " Yaş";
      else if (d_effective <= new Date('2041-12-31')) return Math.min(65, base + 3) + " Yaş";
      else if (d_effective <= new Date('2043-12-31')) return Math.min(65, base + 4) + " Yaş";
      else return "65 Yaş";
    }

    function getSonrasiKismiPrim(d_effective) {
      let y = d_effective.getFullYear();
      if (y <= 2008) return "4600 Gün";
      if (y === 2009) return "4700 Gün";
      if (y === 2010) return "4800 Gün";
      if (y === 2011) return "4900 Gün";
      if (y === 2012) return "5000 Gün";
      if (y === 2013) return "5100 Gün";
      if (y === 2014) return "5200 Gün";
      if (y === 2015) return "5300 Gün";
      return "5400 Gün";
    }

