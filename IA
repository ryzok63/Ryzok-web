      option.value = portalAdi;
      option.textContent = portalAdi;
      portalSelect.appendChild(option);
    });

    portalSelect.addEventListener('change', function () {
      const secilenPortal = this.value;
      konuSearchInput.value = "";
      customDropdownList.innerHTML = "";
      resultContainer1.style.display = 'none';

      if (!secilenPortal) {
        konuSearchInput.disabled = true;
        konuSearchInput.placeholder = "Önce portal seçiniz...";
        currentPortalData = [];
        return;
      }

      konuSearchInput.disabled = false;
      konuSearchInput.placeholder = "Aramak istediğiniz konuyu yazın veya listeyi açmak için tıklayın...";
      currentPortalData = portalData[secilenPortal];
      renderPortalDropdownItems(currentPortalData);
    });

    function renderPortalDropdownItems(items) {
      customDropdownList.innerHTML = "";
      if (items.length === 0) {
        customDropdownList.innerHTML = '<div class="custom-dropdown-item2" style="color:#888; cursor:default; font-style:italic;">Eşleşen sonuç bulunamadı...</div>';
        return;
      }
      items.forEach(item => {
        const div = document.createElement('div');
        div.className = "custom-dropdown-item2";
        div.textContent = item.konu;
        div.addEventListener('click', function () {
          konuSearchInput.value = item.konu;
          dinamikBaslik1.textContent = item.konu;
          resMetin1.innerHTML = item.metin;
          resultContainer1.style.display = 'grid';
          customDropdownList.style.display = 'none';
        });
        customDropdownList.appendChild(div);
      });
    }

    konuSearchInput.addEventListener('focus', function () {
